#!/bin/sh
# /www/cgi-bin/mitmweb/status â€” JSON status snapshot for the Status tab.
#
# Why this is a CGI and not a LuCI leaf action: OpenWrt 23.05+ moved
# the LuCI dispatcher to ucode and stopped registering Lua controllers
# via /usr/lib/lua/luci/controller/*.lua. Our previous controller.lua
# file landed on disk but the dispatcher silently ignored it (route
# lookup returned 404), so the Status tab's XHR couldn't reach the
# leaf handler. Serving JSON from /cgi-bin/mitmweb/status bypasses
# the dispatcher entirely: uhttpd ships with cgi_prefix=/cgi-bin so
# any executable file under /www/cgi-bin/ is invoked as CGI, and
# the JS in view/mitmweb/status.htm calls this URL directly.

CONFDIR="$(uci -q get mitmweb.main.confdir 2>/dev/null || echo /etc/mitmweb)"
LOGFILE="/var/log/mitmweb.log"

# --- running pids (array; [] if none) ---
PIDS_JSON="[]"
PIDS_RAW=$(pgrep -f 'mitmweb.bin' 2>/dev/null)
if [ -n "$PIDS_RAW" ]; then
    PIDS_JSON=$(printf '%s' "$PIDS_RAW" | awk 'BEGIN{ORS=","} {printf "\"%s\",", $1}' | sed 's/,$//' | awk '{printf "["$0"]"}')
fi

# --- error report (from /var/log/mitmweb.log if the init.d pre-flight
# check wrote one). Surfaced in the Status tab so the user sees why
# mitmweb isn't running without having to ssh into the device. ---
ERROR_MSG=""
if [ -f "$LOGFILE" ]; then
    ERROR_MSG=$(grep -E '^BINARY STARTUP FAILED|^INCOMPATIBLE LIBC|^BINARY STARTUP' "$LOGFILE" 2>/dev/null | head -n1)
    [ -z "$ERROR_MSG" ] && ERROR_MSG=""
fi

# --- mode (MultiValue â†’ space-joined; empty string in JSON if unset) ---
MODE=$(uci -q get mitmweb.main.mode 2>/dev/null | awk '{$1=$1};1')

# --- web URL ---
WEB_HOST=$(uci -q get mitmweb.main.web_host 2>/dev/null || echo 0.0.0.0)
WEB_PORT=$(uci -q get mitmweb.main.web_port 2>/dev/null || echo 8081)
if [ -z "$WEB_HOST" ] || [ "$WEB_HOST" = "0.0.0.0" ]; then
    WEB_HOST=$(uci -q get network.lan.ipaddr 2>/dev/null | head -n1)
    [ -z "$WEB_HOST" ] && WEB_HOST="192.168.1.1"
fi

# --- CA info (string; quoted properly) ---
CERT="$CONFDIR/.mitmproxy/mitmproxy-ca-cert.pem"
CA_EXISTS="false"
CA_RAW=""
if [ -f "$CERT" ]; then
    CA_EXISTS="true"
    CA_RAW=$(openssl x509 -in "$CERT" -noout -subject -issuer -dates -serial -fingerprint -sha256 2>/dev/null)
fi

# --- log tail ---
LOG_TAIL=""
if [ -f "$LOGFILE" ]; then
    LOG_TAIL=$(tail -n 30 "$LOGFILE" 2>/dev/null)
fi

# Build JSON via printf so we can use %s for the variable parts without
# sub-shelling into awk. Every user-supplied field goes through json_esc.
json_esc() {
    # Escape \ and " and replace newlines / tabs with spaces so the
    # result is a valid single-line JSON string.
    printf '%s' "$1" | awk '
        BEGIN { ORS="" }
        {
            gsub(/\\/, "\\\\")
            gsub(/"/,  "\\\"")
            gsub(/\n/, " ")
            gsub(/\r/, " ")
            gsub(/\t/, " ")
            print
        }'
}

echo "Content-Type: application/json"
echo
printf '{"running": %s, "pids": %s, "mode": "%s", "web_url": "http://%s:%s", "confdir": "%s", "ca_info": {"exists": %s, "raw": "%s"}, "log_tail": "%s", "error": "%s"}\n' \
    "$([ -n "$PIDS_RAW" ] && echo true || echo false)" \
    "$PIDS_JSON" \
    "$(json_esc "$MODE")" \
    "$(json_esc "$WEB_HOST")" \
    "$WEB_PORT" \
    "$(json_esc "$CONFDIR")" \
    "$CA_EXISTS" \
    "$(json_esc "$CA_RAW")" \
    "$(json_esc "$LOG_TAIL")" \
    "$(json_esc "$ERROR_MSG")"